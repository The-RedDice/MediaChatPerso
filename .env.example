# ─── Configuration Globale ──────────────────────────────
PORT=3000
SERVER_URL=http://localhost:3000

# ─── Auth Session et Upload ───────────────────────────────
# Clé secrète pour signer les cookies de session (à changer)
SESSION_SECRET=un_mot_de_passe_très_compliqué

# ─── Identifiants Discord Bot & OAuth ───────────────────
# Token du bot Discord
DISCORD_TOKEN=votre_token_ici

# ID du Client Discord (Application ID)
DISCORD_CLIENT_ID=votre_client_id

# Client Secret de l'application Discord (Oauth2) pour la page d'upload
DISCORD_CLIENT_SECRET=votre_client_secret

# ID du Serveur Discord (Guild)
DISCORD_GUILD_ID=votre_guild_id

# ID du salon Discord où envoyer les votes de réputation (optionnel)
REPUTATION_CHANNEL_ID=

# URI de redirection (à configurer aussi dans le portail Discord > OAuth2)
# Ex: http://mon-ip:3000/auth/discord/callback
DISCORD_REDIRECT_URI=http://localhost:3000/auth/discord/callback

# ─── Panel Web ──────────────────────────────────────────
PANEL_PASSWORD=changeme

# ─── API IA (Vous n'avez besoin que d'une seule clé) ─────
# Alternatives avec paliers gratuits beaucoup plus généreux que Google :
# 1. Obtenir une clé Groq (très rapide) : https://console.groq.com/keys
# GROQ_API_KEY=your_groq_api_key

# 2. Obtenir une clé OpenRouter : https://openrouter.ai/keys
# OPENROUTER_API_KEY=your_openrouter_api_key

# 3. Ou utiliser Google Gemini (déconseillé si vous atteignez souvent la limite)
# GEMINI_API_KEY=your_gemini_api_key

# ─── Sécurité (Optionnel) ───────────────────────────────
# ALLOWED_ORIGINS=http://localhost:8123,http://tauri.localhost
