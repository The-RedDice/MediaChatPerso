{
  "$schema": "https://schema.tauri.app/config/2/capability",
  "identifier": "default",
  "description": "BordelBox overlay capabilities",
  "windows": ["overlay", "options"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "global-shortcut:allow-register",
    "global-shortcut:allow-unregister",
    "global-shortcut:allow-is-registered",
    "core:tray:default",
    "core:menu:default"
  ]
}
